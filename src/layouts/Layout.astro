---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Amy Lam', description = 'Personal site of Amy Lam' } = Astro.props;
const ogImage = new URL('/og.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Link previews (LinkedIn, Slack, iMessage, X): without these a
         shared link renders bare. og.png is a dusk-sky capture of the
         homepage — regenerate with scripts/generate-og.mjs. -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="relative antialiased">
    <!-- Phones size against vw with a gentler blur: 45vmin of a 375px
         screen is a ~170px circle, and the fixed 90px blur smears that
         to near-invisibility (the desktop glow is ~2x the size, so the
         same blur reads as soft rather than gone). -->
    <div
      id="glow"
      aria-hidden="true"
      class="pointer-events-none fixed h-[60vw] w-[60vw] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-0 blur-[55px] sm:h-[45vmin] sm:w-[45vmin] sm:blur-[90px]"
    >
    </div>

    <!-- The moon: not a picture of a moon at all — just the brightest
         light in the sky, a soft luminous point like Venus at dusk.
         Every literal rendering (blurred disc, phase pie-chart, vector
         crescent) eventually read as fake next to the 1-3px stars;
         a point of light belongs to their family. The phase lives in
         the status line's words instead. Brightness follows the real
         illuminated fraction, the glow goes horizon-gold when the moon
         rides low (.moon-low), and nearby stars wash out (sky.ts) so
         nothing sits "on top of" it. Styling in global.css. -->
    <div
      id="moon-core"
      aria-hidden="true"
      class="pointer-events-none fixed h-[7px] w-[7px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-0"
    >
    </div>

    <!-- The moon's revealed face: the one place the "never a picture"
         rule breaks, on purpose. While the triple-tap show plays,
         sky.ts centers this large on the page (the hero text bows out)
         and the resting star-point hides so only the face carries the
         light. The lit shape
         is the real phase geometry — the terminator is an elliptical arc,
         so crescents are crescents and gibbous is gibbous, not a circle
         sliding off another circle. sky.ts positions it with the moon and
         rewrites the shadow path each tick; visibility and the bloom
         transition live in global.css under html.moon-cycle. -->
    <div
      id="moon-face"
      aria-hidden="true"
      class="pointer-events-none fixed h-14 w-14 -translate-x-1/2 -translate-y-1/2"
    >
      <svg viewBox="0 0 100 100" class="h-full w-full">
        <defs>
          <radialGradient id="moon-sphere" cx="42%" cy="38%" r="72%">
            <stop offset="0%" stop-color="#f2f5fb"></stop>
            <stop offset="70%" stop-color="#dde4f0"></stop>
            <stop offset="100%" stop-color="#c3cde0"></stop>
          </radialGradient>
          <clipPath id="moon-clip"><circle cx="50" cy="50" r="49"></circle></clipPath>
        </defs>
        <circle cx="50" cy="50" r="49" fill="url(#moon-sphere)"></circle>
        <!-- Maria: the big soft dark seas, then a scatter of craters.
             All clipped to the disc; tones stay in the site's blue-gray
             family rather than photographic gray. -->
        <g clip-path="url(#moon-clip)" fill="#8fa0c0">
          <ellipse cx="38" cy="34" rx="16" ry="12" opacity="0.35"></ellipse>
          <ellipse cx="62" cy="28" rx="10" ry="8" opacity="0.28"></ellipse>
          <ellipse cx="58" cy="52" rx="13" ry="10" opacity="0.3"></ellipse>
          <ellipse cx="30" cy="60" rx="8" ry="7" opacity="0.25"></ellipse>
          <circle cx="72" cy="66" r="6" opacity="0.32"></circle>
          <circle cx="46" cy="74" r="4.5" opacity="0.35"></circle>
          <circle cx="24" cy="42" r="3" opacity="0.4"></circle>
          <circle cx="66" cy="44" r="2.5" opacity="0.4"></circle>
          <circle cx="52" cy="14" r="3.5" opacity="0.3"></circle>
          <circle cx="80" cy="38" r="2" opacity="0.35"></circle>
          <circle cx="36" cy="86" r="3" opacity="0.3"></circle>
        </g>
        <!-- The night side. sky.ts rewrites d each tick; deep sky navy
             rather than black, so the dark limb reads as sky swallowing
             the disc, with the surface just barely ghosting through. -->
        <path id="moon-shadow" d="" fill="#0a1030" opacity="0.94"></path>
      </svg>
    </div>

    <!-- The finale wash: when the show's month of phases completes,
         moonlight rises softly from the stage and recedes (sky.ts).
         Sits below the page content in DOM order so the flood stays
         behind the text. -->
    <div id="moon-finale" aria-hidden="true" class="pointer-events-none fixed inset-0 opacity-0">
    </div>

    <!-- Day-show shower cloud: a faint gray dim over the sky while the
         rain falls, lifting when the rainbow arrives (sky.ts). -->
    <div id="cloud-dim" aria-hidden="true" class="pointer-events-none fixed inset-0 opacity-0"></div>

    <!-- Day-show rainbow: the left leg of a bow whose arch is far off
         the upper right — mostly horizontal across the page, sweeping
         up as it exits (sky.ts triggers it; geometry in global.css). -->
    <div id="rainbow" aria-hidden="true" class="pointer-events-none fixed"></div>

    <!-- The easter egg's trigger is a triple-tap anywhere on the sky
         (sky.ts) — no dedicated touch target needed, so nothing ever
         sits above the page content stealing taps. Night with the moon
         up: the month of phases. Daylight: a shower and a rainbow.
         Dark, moonless sky: a scatter of shooting stars. -->


    <!-- The real night sky: sky.ts positions the brightest stars for the
         visitor's location and time. -->
    <div id="stars" aria-hidden="true" class="pointer-events-none fixed inset-0 opacity-0"></div>

    <!-- Contrast scrim: sky.ts raises its opacity when the gradient behind
         the center content can't meet AAA on its own (golden hour). -->
    <div
      id="scrim"
      aria-hidden="true"
      class="pointer-events-none fixed top-[48%] left-1/2 h-[44vh] w-[min(96vw,64rem)] -translate-x-1/2 -translate-y-1/2 rounded-[50%] opacity-0 blur-3xl"
    >
    </div>

    <!-- The horizon band: the sky settles into the chip color at ground
         level; nav, status, and the buttons all sit on its solid zone. -->
    <div
      id="horizon"
      aria-hidden="true"
      class="pointer-events-none fixed inset-x-0 bottom-0 h-40 sm:h-32"
    >
    </div>

    <slot />

    <!-- Mobile: anchored to the bottom of the page (absolute against the
         relative body), so on scrollable pages the chips rest below the
         content instead of floating over text and photos mid-scroll.
         Desktop keeps them viewport-fixed, with the scroll-fade in sky.ts
         handling overlap. -->
    <div
      id="sky-controls"
      class="absolute right-5 bottom-[calc(1.25rem+env(safe-area-inset-bottom))] flex items-center gap-4 sm:fixed"
    >
      <button
        id="sky-demo"
        aria-label="Play a 24-hour sky time-lapse"
        class="sky-chip relative rounded-full border border-current/30 px-3 py-1.5 text-xs lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-2 after:content-[''] hover:-translate-y-0.5 hover:border-current/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
      >
        ▶︎ 24h
      </button>
      <button
        id="sky-mode"
        class="sky-chip relative rounded-full border border-current/30 px-3 py-1.5 text-xs lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-2 after:content-[''] hover:-translate-y-0.5 hover:border-current/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
      >
        sky: auto
      </button>
    </div>
    <script src="../scripts/sky.ts"></script>
  </body>
</html>
