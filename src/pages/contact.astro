---
import Layout from '../layouts/Layout.astro';
---

<Layout title="contact — Amy Lam" description="Get in touch with Amy Lam.">
  <!-- pb clears the fixed horizon band + chips, same as the about page. -->
  <main class="relative mx-auto flex min-h-dvh max-w-2xl flex-col gap-6 px-6 pt-20 pb-48">
    <a
      href="/"
      class="link-squiggle sky-top-ink relative self-start text-[19px] font-bold lowercase tracking-wide transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← home
    </a>

    <h1 class="text-4xl font-medium lowercase tracking-tight sm:text-5xl">contact</h1>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <div class="prose sm:prose-lg max-w-none">
        <p>
          I grew up with my grandparents on the Connecticut shoreline, where Pop kept a
          little dinghy in the harbor named <em>Youth Phase</em>. Each time life carried him
          somewhere new, he'd update the letters on the hull — even in his old age, he never
          stopped counting.
        </p>
      </div>

      <!-- Youth Phase, drawn rather than photographed — the same
           one-exception move as the moon face. A flat-lay interpretation
           of the family photo: the boat seen from above at the photo's
           diagonal, lettered at the bow, on rippled water that fills the
           whole frame. The water is the live sky variables, so the scene
           sits in whatever weather the visitor's sky is having; the hull
           is polaroid ivory, the site's one deliberately sky-independent
           color. A slow ride on the swell, ripples drifting — stilled
           under prefers-reduced-motion. -->
      <figure class="dinghy-scene mt-8">
        <svg
          viewBox="0 0 600 340"
          role="img"
          aria-label="An illustrated overhead view of a small white dinghy, YOUTH PHASE IX lettered at the bow, floating on rippled water that mirrors the current sky — drawn after a family photo"
          class="block w-full rounded-2xl"
        >
          <defs>
            <linearGradient id="sea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--sky-bottom, #1e2c60)"></stop>
              <stop offset="1" stop-color="var(--sky-top, #0a1030)"></stop>
            </linearGradient>
          </defs>

          <!-- Open water, edge to edge — no horizon, like the photo. -->
          <rect x="0" y="0" width="600" height="340" fill="url(#sea)"></rect>
          <rect x="0" y="0" width="600" height="340" fill="#0a1030" opacity="0.22"></rect>

          <!-- The patch of reflected light the photo catches at the top
               left — horizon gold, barely there. -->
          <ellipse cx="150" cy="80" rx="150" ry="70" fill="#ffeecf" opacity="0.035"></ellipse>
          <ellipse cx="470" cy="270" rx="120" ry="55" fill="#f0f4ff" opacity="0.025"></ellipse>

          <!-- Ripple texture, drifting on offset periods. -->
          <g stroke="#f0f4ff" fill="none" stroke-linecap="round">
            <path class="ripple ripple-1" d="M40 52 q34 -6 70 0" stroke-width="2" opacity="0.16"></path>
            <path class="ripple ripple-2" d="M420 46 q40 -7 82 0" stroke-width="2" opacity="0.14"></path>
            <path class="ripple ripple-3" d="M120 118 q30 -5 60 0" stroke-width="1.5" opacity="0.18"></path>
            <path class="ripple ripple-2" d="M478 140 q32 -6 64 0" stroke-width="2" opacity="0.16"></path>
            <path class="ripple ripple-1" d="M60 220 q36 -7 74 0" stroke-width="2" opacity="0.15"></path>
            <path class="ripple ripple-3" d="M470 230 q28 -5 56 0" stroke-width="1.5" opacity="0.13"></path>
            <path class="ripple ripple-2" d="M130 296 q40 -7 80 0" stroke-width="2.5" opacity="0.12"></path>
            <path class="ripple ripple-1" d="M400 306 q34 -6 68 0" stroke-width="2" opacity="0.14"></path>
            <path class="ripple ripple-3" d="M280 40 q26 -5 52 0" stroke-width="1.5" opacity="0.12"></path>
          </g>

          <!-- The boat, tilted at the photo's diagonal. Everything that
               rides with the hull — shadow, contact ripples, lettering —
               lives inside the bob group so the swell moves it as one. -->
          <g transform="rotate(-14 300 175)">
            <g class="dinghy">
              <!-- Cast shadow on the water, offset toward the lower
                   right. -->
              <path
                d="M270 78 Q312 70 344 82 Q366 106 366 160 Q366 218 318 286 Q312 294 306 286 Q262 218 260 160 Q260 106 270 78 Z"
                transform="translate(12 12)"
                fill="#0a1030"
                opacity="0.3"
              ></path>

              <!-- Contact ripples hugging the hull. -->
              <g stroke="#f0f4ff" fill="none" stroke-linecap="round" opacity="0.35">
                <path d="M250 120 Q244 170 252 214" stroke-width="2"></path>
                <path d="M376 116 Q384 168 374 216" stroke-width="2"></path>
                <path d="M290 300 Q312 312 334 296" stroke-width="2"></path>
              </g>

              <!-- Hull: ivory, rounded transom at the stern (top),
                   tapering to the bow point (bottom). -->
              <path
                d="M266 76 Q312 66 346 80 Q368 106 368 160 Q368 220 318 290 Q312 298 306 290 Q258 220 258 160 Q258 106 266 76 Z"
                fill="#f7f4ed"
              ></path>

              <!-- Interior: gunwale rim, floor, thwarts — stopping short
                   of the bow so the foredeck stays ivory for the name. -->
              <path
                d="M274 88 Q312 80 340 90 Q356 112 356 160 Q356 196 322 238 Q312 244 304 238 Q270 196 270 160 Q270 112 274 88 Z"
                fill="#8fa0c0"
              ></path>
              <path
                d="M280 96 Q312 89 334 97 Q348 116 348 160 Q348 190 318 228 Q312 233 306 228 Q278 190 278 160 Q278 116 280 96 Z"
                fill="#dde4f0"
                opacity="0.55"
              ></path>
              <!-- Stern seat and the middle thwart. -->
              <path d="M276 106 Q312 98 350 104 L350 122 Q312 114 276 122 Z" fill="#f7f4ed" opacity="0.85"></path>
              <path d="M271 168 L355 168 L355 186 L271 186 Z" fill="#f7f4ed" opacity="0.85"></path>
              <!-- The round fender resting on the thwart, from the
                   photo. -->
              <circle cx="330" cy="177" r="9" fill="#f7f4ed"></circle>
              <circle cx="330" cy="177" r="3.5" fill="#8fa0c0" opacity="0.6"></circle>
              <!-- An oar laid across, blade over the side. -->
              <path d="M262 208 L352 150" stroke="#f7f4ed" stroke-width="4" stroke-linecap="round"></path>
              <path d="M352 150 Q366 138 372 144 Q376 150 362 158 Z" fill="#f7f4ed"></path>

              <!-- The name on the foredeck, the way Pop laid it out:
                   name across, numeral beneath. -->
              <text
                x="312"
                y="253"
                text-anchor="middle"
                fill="#1e2c60"
                style="font-size: 9px; font-weight: 500; letter-spacing: 0.03em;"
              >
                YOUTH PHASE
              </text>
              <text
                x="310"
                y="265"
                text-anchor="middle"
                fill="#1e2c60"
                style="font-size: 10px; font-weight: 500; letter-spacing: 0.08em;"
              >
                IX
              </text>
            </g>
          </g>
        </svg>
        <figcaption class="pt-3 text-center text-sm lowercase tracking-widest">
          youth phase · phase ix
        </figcaption>
      </figure>

      <!-- The handoff line: to the form, or to the code for the
           engineers who got curious. The link carries the full system
           treatment: squiggle underline plus the hover lift
           (inline-block so the transform actually applies). -->
      <p class="mt-8 text-sm lowercase tracking-wide">
        send me a message below, or read about
        <a
          href="https://github.com/amyrlam/youthphase"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="how this site is built (opens in new tab)"
          class="link-squiggle inline-block transition-transform duration-300 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
          >how this site is built</a
        > on github.
      </p>
    </section>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <form id="contact-form" class="flex flex-col gap-5" novalidate>
        <div class="flex flex-col gap-1.5">
          <label for="contact-name" class="text-xs lowercase tracking-widest">name</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            maxlength="200"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-email" class="text-xs lowercase tracking-widest">email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            maxlength="254"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-message" class="text-xs lowercase tracking-widest">message</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            maxlength="5000"
            class="resize-y rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          ></textarea>
        </div>

        <!-- Honeypot: hidden from people (and from the accessibility tree),
             irresistible to bots. The server treats any value here as spam. -->
        <div class="hidden" aria-hidden="true">
          <label for="contact-website">leave this field empty</label>
          <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="flex items-center gap-4">
          <button
            type="submit"
            id="contact-submit"
            class="relative w-fit rounded-full border border-current/30 px-4 py-1.5 text-xs lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-2 after:content-[''] hover:-translate-y-0.5 hover:border-current/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current disabled:opacity-60 disabled:hover:translate-y-0 disabled:hover:border-current/30"
          >
            send
          </button>
          <p id="contact-status" aria-live="polite" class="text-sm lowercase tracking-wide"></p>
        </div>
      </form>

    </section>
  </main>
</Layout>

<style>
  /* At anchor: the whole boat rides a slow swell — a couple of pixels of
     drift and a fraction of a degree of swing, never more. Weather-speed
     (7s+), matching the sky's own unhurried transitions. */
  .dinghy {
    transform-origin: 312px 180px;
    animation: dinghy-bob 7s ease-in-out infinite;
  }

  .ripple {
    animation: ripple-drift 11s ease-in-out infinite;
  }

  .ripple-2 {
    animation-duration: 14s;
    animation-delay: -4s;
  }

  .ripple-3 {
    animation-duration: 17s;
    animation-delay: -9s;
  }

  @keyframes dinghy-bob {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    50% {
      transform: translate(2px, 3px) rotate(-0.8deg);
    }
  }

  @keyframes ripple-drift {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(14px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dinghy,
    .ripple {
      animation: none;
    }
  }
</style>

<script>
  /* Progressive enhancement over /api/contact (a Vercel function — under
     plain `astro dev` it doesn't exist, so local testing needs `vercel
     dev`; the error state covers the 404 gracefully). */
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Native validation, surfaced in the site's voice.
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    if (submit) submit.disabled = true;
    if (submit) submit.textContent = 'sending…';
    if (status) status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`send failed: ${res.status}`);
      form.reset();
      if (status) status.textContent = "message sent — i'll write back soon";
    } catch {
      if (status) status.textContent = 'something went wrong — mind trying again?';
    } finally {
      if (submit) {
        submit.disabled = false;
        submit.textContent = 'send';
      }
    }
  });
</script>
