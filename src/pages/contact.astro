---
import Layout from '../layouts/Layout.astro';
---

<Layout title="contact — Amy Lam" description="Get in touch with Amy Lam.">
  <!-- pb clears the fixed horizon band + chips, same as the about page. -->
  <main class="relative mx-auto flex min-h-dvh max-w-2xl flex-col gap-6 px-6 pt-20 pb-48">
    <a
      href="/"
      class="link-squiggle sky-top-ink relative self-start text-[19px] font-bold lowercase tracking-wide transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← home
    </a>

    <h1 class="text-4xl font-medium lowercase tracking-tight sm:text-5xl">contact</h1>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <div class="prose sm:prose-lg max-w-none">
        <p>
          I grew up with my grandparents on the Connecticut shoreline, where Pop kept a
          little dinghy in the harbor named <em>Youth Phase</em>. Each time life carried him
          somewhere new, he'd repaint the numeral on her hull — even in his old age, he
          never stopped counting. This site is named for her.
        </p>
      </div>

      <!-- Youth Phase herself, drawn rather than photographed — the same
           one-exception move as the moon face. The water is filled with
           the live sky variables, so the harbor sits in whatever weather
           the visitor's sky is having; the hull is polaroid ivory, the
           site's one deliberately sky-independent color. She rides at
           anchor: a slow bob, drifting ripples, a drooping pennant —
           weather-speed motion, stilled under prefers-reduced-motion. -->
      <figure class="dinghy-scene mt-8">
        <svg
          viewBox="0 0 600 340"
          role="img"
          aria-label="An illustrated white dinghy named Youth Phase, the numeral IX on her hull, riding at anchor on water that mirrors the current sky, with a wooded shoreline and moored sailboats in the distance"
          class="block w-full rounded-2xl"
        >
          <defs>
            <!-- The sea inverts the sky gradient — near water carries the
                 horizon color, deep water the zenith color — like a real
                 reflection. -->
            <linearGradient id="sea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--sky-bottom, #1e2c60)"></stop>
              <stop offset="1" stop-color="var(--sky-top, #0a1030)"></stop>
            </linearGradient>
          </defs>

          <!-- Above the horizon the card background is the sky. Distant
               shoreline and moored neighbors in currentColor, so they
               keep contrast whatever ink the sky computes. -->
          <g fill="currentColor" opacity="0.22">
            <path
              d="M0 170 C40 156 90 160 130 165 C180 150 240 158 290 164 C350 152 420 158 470 163 C520 154 570 160 600 166 L600 170 Z"
            ></path>
          </g>
          <g stroke="currentColor" stroke-width="1.5" opacity="0.35" fill="none">
            <line x1="88" y1="118" x2="88" y2="168"></line>
            <line x1="480" y1="128" x2="480" y2="167"></line>
            <line x1="540" y1="140" x2="540" y2="168"></line>
          </g>
          <!-- One neighbor keeps her sail up — without at least one sail
               silhouette the distant masts read as pilings. -->
          <path d="M480 130 L480 164 L462 164 Z" fill="currentColor" opacity="0.25"></path>
          <g fill="currentColor" opacity="0.35">
            <path d="M74 168 q14 8 30 0 z"></path>
            <path d="M468 167 q12 7 26 0 z"></path>
            <path d="M529 168 q11 6 23 0 z"></path>
          </g>

          <!-- The water. A whisper of night-navy keeps the ivory hull
               legible even under a pale midday sky. -->
          <rect x="0" y="170" width="600" height="170" fill="url(#sea)"></rect>
          <rect x="0" y="170" width="600" height="170" fill="#0a1030" opacity="0.18"></rect>

          <!-- Her reflection: a soft ivory smudge, shimmering slowly. -->
          <ellipse class="dinghy-reflection" cx="300" cy="268" rx="92" ry="10" fill="#f7f4ed" opacity="0.14">
          </ellipse>

          <!-- Ripples in moonlight, each drifting on its own period. -->
          <g stroke="#f0f4ff" fill="none" stroke-linecap="round">
            <path class="ripple ripple-1" d="M120 262 q30 -6 62 0" stroke-width="2" opacity="0.28"></path>
            <path class="ripple ripple-2" d="M400 278 q38 -7 78 0" stroke-width="2" opacity="0.22"></path>
            <path class="ripple ripple-3" d="M180 300 q44 -8 90 0" stroke-width="2.5" opacity="0.18"></path>
            <path class="ripple ripple-2" d="M420 316 q30 -6 60 0" stroke-width="2" opacity="0.14"></path>
            <path class="ripple ripple-3" d="M90 226 q26 -5 52 0" stroke-width="1.5" opacity="0.2"></path>
          </g>

          <!-- Youth Phase. Side profile, bow to the right, like she's
               swung on her mooring to face the tide. -->
          <g class="dinghy">
            <!-- Mast stub and the drooping pennant from the photo. -->
            <line x1="286" y1="212" x2="282" y2="102" stroke="#8fa0c0" stroke-width="3" stroke-linecap="round"
            ></line>
            <path
              class="pennant"
              d="M282 102 q20 4 34 14 q-16 10 -30 6 q-3 -10 -4 -20 z"
              fill="#f7f4ed"
              opacity="0.95"
            ></path>

            <!-- Hull: ivory sides, a navy waterline stroke, the sheer
                 dipping amidships like a real lapstrake dinghy. -->
            <path
              d="M196 212 C240 220 360 220 404 208 C412 206 418 210 414 218 C404 240 380 252 300 252 C228 252 206 240 198 224 C195 218 193 212 196 212 Z"
              fill="#f7f4ed"
            ></path>
            <!-- Interior shadow along the sheer. -->
            <path
              d="M204 214 C244 221 356 221 400 210 C396 218 380 224 300 224 C240 224 216 220 204 214 Z"
              fill="#8fa0c0"
              opacity="0.5"
            ></path>
            <!-- Rub rail. -->
            <path
              d="M196 212 C240 220 360 220 404 208"
              fill="none"
              stroke="#1e2c60"
              stroke-width="2.5"
              stroke-linecap="round"
              opacity="0.55"
            ></path>
            <!-- Lapstrake plank lines. -->
            <path d="M206 230 C250 238 352 238 402 226" fill="none" stroke="#c3cde0" stroke-width="1.5" opacity="0.7"></path>
            <path d="M214 241 C256 247 346 247 394 237" fill="none" stroke="#c3cde0" stroke-width="1.5" opacity="0.5"></path>

            <!-- Her name, painted the way Pop painted it. -->
            <text
              x="300"
              y="243"
              text-anchor="middle"
              fill="#1e2c60"
              style="font-size: 15px; font-weight: 500; letter-spacing: 0.18em;"
            >
              YOUTH PHASE
            </text>
            <text
              x="384"
              y="238"
              text-anchor="middle"
              fill="#1e2c60"
              style="font-size: 14px; font-weight: 500; letter-spacing: 0.08em;"
            >
              IX
            </text>
          </g>
        </svg>
        <figcaption class="pt-3 text-center text-sm lowercase tracking-widest">
          youth phase, at anchor · phase ix
        </figcaption>
      </figure>
    </section>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <form id="contact-form" class="flex flex-col gap-5" novalidate>
        <div class="flex flex-col gap-1.5">
          <label for="contact-name" class="text-xs lowercase tracking-widest">name</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            maxlength="200"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-email" class="text-xs lowercase tracking-widest">email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            maxlength="254"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-message" class="text-xs lowercase tracking-widest">message</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            maxlength="5000"
            class="resize-y rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          ></textarea>
        </div>

        <!-- Honeypot: hidden from people (and from the accessibility tree),
             irresistible to bots. The server treats any value here as spam. -->
        <div class="hidden" aria-hidden="true">
          <label for="contact-website">leave this field empty</label>
          <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="flex items-center gap-4">
          <button
            type="submit"
            id="contact-submit"
            class="relative w-fit rounded-full border border-current/30 px-4 py-1.5 text-xs lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-2 after:content-[''] hover:-translate-y-0.5 hover:border-current/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current disabled:opacity-60 disabled:hover:translate-y-0 disabled:hover:border-current/30"
          >
            send
          </button>
          <p id="contact-status" aria-live="polite" class="text-sm lowercase tracking-wide"></p>
        </div>
      </form>
    </section>
  </main>
</Layout>

<style>
  /* At anchor: the whole boat rides a slow swell — a couple of pixels of
     lift and a degree of heel, never more. Weather-speed (7s+), matching
     the sky's own unhurried transitions. */
  .dinghy {
    transform-origin: 300px 232px;
    animation: dinghy-bob 7s ease-in-out infinite;
  }

  .pennant {
    transform-origin: 282px 102px;
    animation: pennant-sway 5s ease-in-out infinite;
  }

  .dinghy-reflection {
    animation: reflection-shimmer 7s ease-in-out infinite;
  }

  .ripple {
    animation: ripple-drift 11s ease-in-out infinite;
  }

  .ripple-2 {
    animation-duration: 14s;
    animation-delay: -4s;
  }

  .ripple-3 {
    animation-duration: 17s;
    animation-delay: -9s;
  }

  @keyframes dinghy-bob {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(3px) rotate(-1.1deg);
    }
  }

  @keyframes pennant-sway {
    0%,
    100% {
      transform: skewY(0deg);
    }
    50% {
      transform: skewY(-4deg);
    }
  }

  @keyframes reflection-shimmer {
    0%,
    100% {
      opacity: 0.14;
      transform: scaleX(1);
    }
    50% {
      opacity: 0.09;
      transform: scaleX(0.96);
    }
  }

  @keyframes ripple-drift {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(14px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dinghy,
    .pennant,
    .dinghy-reflection,
    .ripple {
      animation: none;
    }
  }
</style>

<script>
  /* Progressive enhancement over /api/contact (a Vercel function — under
     plain `astro dev` it doesn't exist, so local testing needs `vercel
     dev`; the error state covers the 404 gracefully). */
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Native validation, surfaced in the site's voice.
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    if (submit) submit.disabled = true;
    if (submit) submit.textContent = 'sending…';
    if (status) status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`send failed: ${res.status}`);
      form.reset();
      if (status) status.textContent = "message sent — i'll write back soon";
    } catch {
      if (status) status.textContent = 'something went wrong — mind trying again?';
    } finally {
      if (submit) {
        submit.disabled = false;
        submit.textContent = 'send';
      }
    }
  });
</script>
