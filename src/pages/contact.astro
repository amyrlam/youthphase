---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

/* youth-phase-print.png is the retouched cut of youth-phase-2.png (the
   original stays in the repo): cropped from photo-of-a-photo to just
   the print, with the drifting plastic bag cloned out of the water. */
import youthPhase from '../assets/contact/youth-phase-print.png';
---

<Layout title="contact — Amy Lam" description="Get in touch with Amy Lam.">
  <!-- pb clears the fixed horizon band + chips, same as the about page. -->
  <main class="relative mx-auto flex min-h-dvh max-w-2xl flex-col gap-6 px-6 pt-20 pb-48">
    <a
      href="/"
      class="link-squiggle sky-top-ink relative self-start text-[19px] font-bold lowercase tracking-wide transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← home
    </a>

    <h1 class="text-4xl font-medium lowercase tracking-tight sm:text-5xl">contact</h1>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <div class="prose sm:prose-lg max-w-none">
        <p>
          I grew up with my grandparents on the Connecticut shoreline, where Pop kept a
          little dinghy in the harbor named <em>Youth Phase</em>. Each time life carried him
          somewhere new, he'd update the letters on the hull — even in his old age, he never
          stopped counting.
        </p>
      </div>

      <!-- The photo itself, hung in a gold frame — a family print given
           the heirloom treatment. The frame is layered CSS (gradient
           gilt, beveled inset rings, a real drop shadow); the print is
           the retouched crop. astro:assets optimizes it at build time. -->
      <div class="gold-frame mt-8">
        <Image
          src={youthPhase}
          alt="A photo print of Pop's dinghy: a small white boat floating on rippled dusk water, YOUTH PHASE 2 lettered on the bow"
          width={1200}
          class="block w-full"
        />
      </div>

      <!-- The handoff line: to the form, or to the code. Sentence case
           and body-sized — it's prose, not chrome. The link carries the
           full system treatment: squiggle underline plus the hover lift
           (inline-block so the transform applies). -->
      <p class="mt-8 text-base sm:text-lg">
        Send me a message below, or read about
        <a
          href="https://github.com/amyrlam/youthphase"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="how this site is built (opens in new tab)"
          class="link-squiggle inline-block transition-transform duration-300 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
          >how this site is built</a
        > on GitHub.
      </p>
    </section>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <form id="contact-form" class="flex flex-col gap-5" novalidate>
        <div class="flex flex-col gap-1.5">
          <label for="contact-name" class="text-xs lowercase tracking-widest">name</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            autocomplete="name"
            maxlength="200"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <!-- The asterisk is visual shorthand; assistive tech already
               announces required from the input's own attribute. -->
          <label for="contact-email" class="text-xs lowercase tracking-widest">
            email <span aria-hidden="true">*</span>
          </label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            maxlength="254"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-message" class="text-xs lowercase tracking-widest">
            message <span aria-hidden="true">*</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            maxlength="5000"
            class="resize-y rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          ></textarea>
        </div>

        <!-- Honeypot: hidden from people (and from the accessibility tree),
             irresistible to bots. The server treats any value here as spam. -->
        <div class="hidden" aria-hidden="true">
          <label for="contact-website">leave this field empty</label>
          <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="flex items-center gap-4">
          <button
            type="submit"
            id="contact-submit"
            class="relative w-fit rounded-full border border-current/30 px-4 py-1.5 text-xs lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-2 after:content-[''] hover:-translate-y-0.5 hover:border-current/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current disabled:opacity-60 disabled:hover:translate-y-0 disabled:hover:border-current/30"
          >
            send
          </button>
          <p id="contact-status" aria-live="polite" class="text-sm lowercase tracking-wide"></p>
        </div>
      </form>

    </section>
  </main>
</Layout>

<style>
  /* The antique gilt frame, all CSS. Reading outside-in: a dark outer
     edge, a bright fillet, the wide carved band (diagonal gradient for
     the gilt, a repeating diagonal hatch for tooling marks, radial
     rosettes at the corners), a beaded inner ring (dotted border on the
     ::before), and finally the dark rebate the print sits in. Two drop
     shadows — one deep, one tight — hang it off the card. */
  .gold-frame {
    --frame-w: clamp(1.1rem, 3.5vw, 1.7rem);
    position: relative;
    padding: var(--frame-w);
    border-radius: 0.5rem;
    background:
      radial-gradient(circle at calc(0.55 * var(--frame-w)) calc(0.55 * var(--frame-w)),
        #f7e7b0 0 3px, #7a5c1e 4px 6px, rgba(247, 231, 176, 0.55) 7px 8px, transparent 9px),
      radial-gradient(circle at calc(100% - 0.55 * var(--frame-w)) calc(0.55 * var(--frame-w)),
        #f7e7b0 0 3px, #7a5c1e 4px 6px, rgba(247, 231, 176, 0.55) 7px 8px, transparent 9px),
      radial-gradient(circle at calc(0.55 * var(--frame-w)) calc(100% - 0.55 * var(--frame-w)),
        #f7e7b0 0 3px, #7a5c1e 4px 6px, rgba(247, 231, 176, 0.55) 7px 8px, transparent 9px),
      radial-gradient(circle at calc(100% - 0.55 * var(--frame-w)) calc(100% - 0.55 * var(--frame-w)),
        #f7e7b0 0 3px, #7a5c1e 4px 6px, rgba(247, 231, 176, 0.55) 7px 8px, transparent 9px),
      repeating-linear-gradient(45deg,
        rgba(255, 243, 205, 0.16) 0 2px, rgba(90, 66, 16, 0.14) 2px 4px, transparent 4px 7px),
      linear-gradient(135deg,
        #6d5119, #c9a24a 16%, #f3e2a5 34%, #a8842f 52%, #e6cc7f 72%, #b8913a 88%, #6d5119);
    box-shadow:
      inset 0 0 0 2px rgba(58, 42, 8, 0.65),
      inset 0 0 0 4px rgba(255, 243, 205, 0.6),
      inset 0 0 0 6px rgba(122, 92, 30, 0.55),
      0 24px 55px -16px rgba(0, 0, 0, 0.6),
      0 4px 14px rgba(0, 0, 0, 0.3);
  }

  /* The beaded ring: a dotted border reads as a chain of gilt beads
     around the print — the classic antique-frame detail. */
  .gold-frame::before {
    content: '';
    position: absolute;
    inset: calc(var(--frame-w) - 0.5rem);
    border: 0.26rem dotted rgba(247, 231, 176, 0.85);
    border-radius: 0.3rem;
    pointer-events: none;
    filter: drop-shadow(0 1px 0 rgba(58, 42, 8, 0.55));
  }

  .gold-frame img {
    border-radius: 2px;
    /* The rebate: a dark lip where the print sits in the frame. */
    box-shadow:
      inset 0 0 0 2px rgba(42, 30, 6, 0.65),
      inset 0 2px 6px rgba(0, 0, 0, 0.35);
  }
</style>

<script>
  /* Progressive enhancement over /api/contact (a Vercel function — under
     plain `astro dev` it doesn't exist, so local testing needs `vercel
     dev`; the error state covers the 404 gracefully). */
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Native validation, surfaced in the site's voice.
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    if (submit) submit.disabled = true;
    if (submit) submit.textContent = 'sending…';
    if (status) status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`send failed: ${res.status}`);
      form.reset();
      if (status) status.textContent = "message sent — i'll write back soon";
    } catch {
      if (status) status.textContent = 'something went wrong — mind trying again?';
    } finally {
      if (submit) {
        submit.disabled = false;
        submit.textContent = 'send';
      }
    }
  });
</script>
