---
import Layout from '../layouts/Layout.astro';

/* The dinghy is 8-bit: an ASCII map compiled to a box-shadow pixel
   sprite at build time, so the shipped page is pure CSS. Stern view,
   the way the boat sits when you look out from the dock. Legend:
   d = navy outline, i = ivory hull, g = interior, l = floor light. */
const SPRITE = [
  '......dddddddddddddd......',
  '....ddiiiiiiiiiiiiiidd....',
  '...dggggggggggggggggggd...',
  '...dggllllllllllllllggd...',
  '..dddddddddddddddddddddd..',
  '..diiiiiiiiiiiiiiiiiiiid..',
  '..diiiiiiiiiiiiiiiiiiiid..',
  '..diiiiiiiiiiiiiiiiiiiid..',
  '...diiiiiiiiiiiiiiiiiid...',
  '...diiiiiiiiiiiiiiiiiid...',
  '....diiiiiiiiiiiiiiiid....',
  '.....diiiiiiiiiiiiiid.....',
  '......dddddddddddddd......',
];
const PIXEL_COLORS: Record<string, string> = {
  d: '#1e2c60',
  i: '#f7f4ed',
  g: '#8fa0c0',
  l: '#dde4f0',
};
function spriteShadow(rows: string[], colors: Record<string, string>) {
  const px: string[] = [];
  rows.forEach((row, y) => {
    [...row].forEach((ch, x) => {
      if (colors[ch]) px.push(`${x}px ${y}px 0 ${colors[ch]}`);
    });
  });
  return px.join(', ');
}
const boatShadow = spriteShadow(SPRITE, PIXEL_COLORS);

/* Wave sprites: short runs of starlight pixels. */
const WAVE = ['ssss..ssssss...ssss'];
const waveShadow = spriteShadow(WAVE, { s: 'rgba(240, 244, 255, 0.35)' });

/* The boat's dark water shadow, one row wider than the hull bottom. */
const KEEL_SHADOW = ['ssssssssssssssssssss'];
const keelShadow = spriteShadow(KEEL_SHADOW, { s: 'rgba(10, 16, 48, 0.4)' });

/* Address letters get a tiny per-letter tilt, like they were mounted
   one at a time. Precomputed, not random — builds are reproducible. */
const JIGGLE = [-2, 1, -1, 2, 0, -1.5, 1.5, -1, 0.5, 2, -2, 1];
const letterSpans = (word: string) =>
  [...word].map((ch, i) => ({ ch, tilt: JIGGLE[i % JIGGLE.length] }));
---

<Layout title="contact — Amy Lam" description="Get in touch with Amy Lam.">
  <!-- pb clears the fixed horizon band + chips, same as the about page. -->
  <main class="relative mx-auto flex min-h-dvh max-w-2xl flex-col gap-6 px-6 pt-20 pb-48">
    <a
      href="/"
      class="link-squiggle sky-top-ink relative self-start text-[19px] font-bold lowercase tracking-wide transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← home
    </a>

    <h1 class="text-4xl font-medium lowercase tracking-tight sm:text-5xl">contact</h1>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <div class="prose sm:prose-lg max-w-none">
        <p>
          I grew up with my grandparents on the Connecticut shoreline, where Pop kept a
          little dinghy in the harbor named <em>Youth Phase</em>. Each time life carried him
          somewhere new, he'd update the letters on the hull — even in his old age, he never
          stopped counting.
        </p>
      </div>

      <!-- Youth Phase in 8-bit — drawn in code, the way the site
           draws its moon. The water is the live sky variables, so the
           scene sits in whatever weather the visitor's sky is having;
           the hull is polaroid ivory. The name is not pixels: it's set
           in serif capitals like the address letters from the hardware
           store, mounted one at a time across the transom. -->
      <figure
        class="pixel-scene mt-8"
        role="img"
        aria-label="A pixel-art dinghy seen from behind, floating on water that mirrors the current sky, YOUTH PHASE XVII in hardware-store address letters across the transom"
      >
        <div class="pixel-water" aria-hidden="true">
          <div class="wave wave-a" style={`box-shadow: ${waveShadow}`}></div>
          <div class="wave wave-b" style={`box-shadow: ${waveShadow}`}></div>
          <div class="wave wave-c" style={`box-shadow: ${waveShadow}`}></div>
          <div class="wave wave-d" style={`box-shadow: ${waveShadow}`}></div>
          <div class="boat-rig">
            <div class="keel-shadow" style={`box-shadow: ${keelShadow}`}></div>
            <div class="boat" style={`box-shadow: ${boatShadow}`}></div>
            <div class="transom-letters">
              <span class="letters-line">
                {letterSpans('YOUTH PHASE').map(({ ch, tilt }) =>
                  ch === ' ' ? <span class="letter-gap"> </span> : <span class="letter" style={`transform: rotate(${tilt}deg)`}>{ch}</span>
                )}
              </span>
              <span class="letters-line letters-numeral">
                {letterSpans('XVII').map(({ ch, tilt }) => (
                  <span class="letter" style={`transform: rotate(${tilt}deg)`}>{ch}</span>
                ))}
              </span>
            </div>
          </div>
        </div>
      </figure>

      <!-- The handoff line: to the form, or to the code. Sentence case
           and body-sized — it's prose, not chrome. The link carries the
           full system treatment: squiggle underline plus the hover lift
           (inline-block so the transform applies). -->
      <p class="mt-8 text-base sm:text-lg">
        Send me a message below, or read about
        <a
          href="https://github.com/amyrlam/youthphase"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="how this site is built (opens in new tab)"
          class="link-squiggle inline-block transition-transform duration-300 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
          >how this site is built</a
        > on GitHub.
      </p>
    </section>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <form id="contact-form" class="flex flex-col gap-5" novalidate>
        <div class="flex flex-col gap-1.5">
          <label for="contact-name" class="text-xs lowercase tracking-widest">name</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            maxlength="200"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-email" class="text-xs lowercase tracking-widest">email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            maxlength="254"
            class="rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-message" class="text-xs lowercase tracking-widest">message</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            maxlength="5000"
            class="resize-y rounded-lg border border-current/30 bg-transparent px-3 py-2 text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          ></textarea>
        </div>

        <!-- Honeypot: hidden from people (and from the accessibility tree),
             irresistible to bots. The server treats any value here as spam. -->
        <div class="hidden" aria-hidden="true">
          <label for="contact-website">leave this field empty</label>
          <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="flex items-center gap-4">
          <button
            type="submit"
            id="contact-submit"
            class="relative w-fit rounded-full border border-current/30 px-4 py-1.5 text-xs lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-2 after:content-[''] hover:-translate-y-0.5 hover:border-current/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current disabled:opacity-60 disabled:hover:translate-y-0 disabled:hover:border-current/30"
          >
            send
          </button>
          <p id="contact-status" aria-live="polite" class="text-sm lowercase tracking-wide"></p>
        </div>
      </form>

    </section>
  </main>
</Layout>

<style>
  /* The scene: open water edge to edge, the sky's own gradient dimmed a
     notch so the ivory hull carries. image-rendering keeps any scaling
     of the pixel grid crisp. */
  .pixel-scene {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    aspect-ratio: 16 / 9;
    background-image:
      linear-gradient(rgba(5, 6, 12, 0.25), rgba(5, 6, 12, 0.25)),
      linear-gradient(180deg, var(--sky-bottom, #1e2c60), var(--sky-top, #0a1030));
    image-rendering: pixelated;
  }

  .pixel-water {
    position: absolute;
    inset: 0;
    /* One pixel = --px screen pixels; sprites are 1px grids scaled up. */
    --px: 8;
  }

  @media (max-width: 640px) {
    .pixel-water {
      --px: 6;
    }
  }

  /* Every sprite is a 1px div whose box-shadow is the artwork; scaling
     happens in the transform so the squares stay sharp. */
  .boat,
  .keel-shadow,
  .wave {
    position: absolute;
    width: 1px;
    height: 1px;
    transform-origin: 0 0;
  }

  .boat-rig {
    position: absolute;
    left: calc(50% - 13px * var(--px));
    top: 30%;
    animation: pixel-bob 7s ease-in-out infinite;
  }

  .boat {
    transform: scale(var(--px));
  }

  /* The dark water under the hull, one sprite-row below the keel. */
  .keel-shadow {
    transform: translate(calc(3px * var(--px)), calc(13px * var(--px))) scale(var(--px));
  }

  /* The address letters, mounted across the transom (sprite rows 5-11,
     x 3-23 → scaled into screen units). Serif capitals like the ones
     from the hardware store, each with its own slight tilt. */
  .transom-letters {
    position: absolute;
    left: calc(3px * var(--px));
    top: calc(5.5px * var(--px));
    width: calc(20px * var(--px));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(0.4px * var(--px));
    font-family: Georgia, 'Times New Roman', serif;
    color: #1e2c60;
    text-transform: uppercase;
  }

  .letters-line {
    display: flex;
    letter-spacing: 0;
  }

  .letter {
    display: inline-block;
    font-size: calc(1.9px * var(--px));
    font-weight: 700;
    line-height: 1;
    /* Raised-letter shading: light catches the top, shadow falls under —
       the screwed-on hardware look. */
    text-shadow:
      0 calc(-0.08px * var(--px)) 0 rgba(255, 255, 255, 0.55),
      0 calc(0.14px * var(--px)) 0 rgba(10, 16, 48, 0.3);
    margin-inline: calc(0.14px * var(--px));
  }

  .letter-gap {
    width: calc(0.8px * var(--px));
  }

  .letters-numeral .letter {
    font-size: calc(2.2px * var(--px));
  }

  /* Waves drift on offset weather-speed periods. */
  .wave {
    transform: scale(var(--px));
  }

  .wave-a {
    left: 12%;
    top: 22%;
    animation: wave-drift 11s ease-in-out infinite;
  }

  .wave-b {
    left: 68%;
    top: 34%;
    animation: wave-drift 14s ease-in-out -4s infinite;
  }

  .wave-c {
    left: 8%;
    top: 72%;
    animation: wave-drift 17s ease-in-out -9s infinite;
  }

  .wave-d {
    left: 62%;
    top: 82%;
    animation: wave-drift 13s ease-in-out -6s infinite;
  }

  /* The swell: whole-pixel steps, like the boat was animated on a
     sprite sheet. */
  @keyframes pixel-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(calc(1px * var(--px)));
    }
  }

  @keyframes wave-drift {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: calc(1.5px * var(--px)) 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boat-rig,
    .wave {
      animation: none;
    }
  }
</style>

<script>
  /* Progressive enhancement over /api/contact (a Vercel function — under
     plain `astro dev` it doesn't exist, so local testing needs `vercel
     dev`; the error state covers the 404 gracefully). */
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Native validation, surfaced in the site's voice.
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    if (submit) submit.disabled = true;
    if (submit) submit.textContent = 'sending…';
    if (status) status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`send failed: ${res.status}`);
      form.reset();
      if (status) status.textContent = "message sent — i'll write back soon";
    } catch {
      if (status) status.textContent = 'something went wrong — mind trying again?';
    } finally {
      if (submit) {
        submit.disabled = false;
        submit.textContent = 'send';
      }
    }
  });
</script>
