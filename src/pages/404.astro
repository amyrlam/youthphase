---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Amy Lam" description="Page not found.">
  <main class="relative flex min-h-dvh flex-col items-center justify-center gap-6 px-6 text-center">
    <h1 class="text-6xl font-medium lowercase tracking-tight sm:text-8xl">404</h1>

    <p class="text-sm lowercase tracking-widest sm:text-base">
      this page drifted off into the night sky
    </p>

    <a
      href="/"
      class="link-squiggle relative text-sm lowercase tracking-widest transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← back home
    </a>
  </main>
</Layout>
