---
import Layout from '../layouts/Layout.astro';

/* Gallup's four domain colors, close to the report's own palette. The
   strengths block sits on a fixed white "paper report" panel (a nod to the
   printed Gallup PDF), so the colors stay saturated and distinguishable
   whatever the sky is doing. Each domain also gets its own shape (an
   improvement on Gallup's color-only bars), plus a visually-hidden name,
   so the coding never relies on color alone. Shape CSS lives in the
   .domain-mark rules below. */
const domains = {
  executing: { label: 'Executing', color: '#7b3fa0', shape: 'square' },
  influencing: { label: 'Influencing', color: '#c96a1a', shape: 'triangle' },
  relationship: { label: 'Relationship building', color: '#3272c8', shape: 'circle' },
  strategic: { label: 'Strategic thinking', color: '#2e8f5a', shape: 'diamond' },
} as const;

type DomainKey = keyof typeof domains;

interface Strength {
  name: string;
  domain: DomainKey;
  blurb: string;
}

const strengths2015: Strength[] = [
  {
    name: 'Futuristic',
    domain: 'strategic',
    blurb: 'Inspired by the future and what could be — energizing others with visions of it.',
  },
  {
    name: 'Restorative',
    domain: 'executing',
    blurb: 'Adept at dealing with problems: figuring out what is wrong and resolving it.',
  },
  {
    name: 'Activator',
    domain: 'influencing',
    blurb: 'Turning thoughts into action — do things now, rather than simply talk about them.',
  },
  {
    name: 'Communication',
    domain: 'influencing',
    blurb: 'Putting thoughts into words easily; a good conversationalist and presenter.',
  },
  {
    name: 'Individualization',
    domain: 'relationship',
    blurb: 'Intrigued by the unique qualities of each person, and how they work together.',
  },
];

const strengths2025: Strength[] = [
  {
    name: 'Empathy',
    domain: 'relationship',
    blurb: "Sensing other people's feelings by imagining yourself in their situations.",
  },
  {
    name: 'Relator',
    domain: 'relationship',
    blurb: 'Close relationships — deep satisfaction in working hard with friends toward a goal.',
  },
  {
    name: 'Ideation',
    domain: 'strategic',
    blurb: 'Fascinated by ideas; finding connections between seemingly disparate phenomena.',
  },
  {
    name: 'Individualization',
    domain: 'relationship',
    blurb: 'Intrigued by the unique qualities of each person, and how they work together.',
  },
  {
    name: 'Communication',
    domain: 'influencing',
    blurb: 'Putting thoughts into words easily; a good conversationalist and presenter.',
  },
];

/* Themes that survived the decade get a little gold star. */
const keepers = new Set(
  strengths2015.map((s) => s.name).filter((n) => strengths2025.some((s) => s.name === n)),
);

const eras = [
  { year: '2015', list: strengths2015 },
  { year: '2025', list: strengths2025 },
];
---

<Layout
  title="just for fun — Amy Lam"
  description="Personality quizzes, internet toys, and other data about Amy of questionable scientific rigor."
>
  <main class="relative mx-auto flex min-h-dvh max-w-2xl flex-col gap-6 px-6 pt-20 pb-48">
    <a
      href="/"
      class="link-squiggle sky-top-ink relative self-start text-[19px] font-bold lowercase tracking-wide transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← home
    </a>

    <h1 class="text-4xl font-medium lowercase tracking-tight sm:text-5xl">just for fun</h1>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <div class="prose prose-lg max-w-none">
        <p>
          Personality tests, internet toys, and other data about me of questionable
          scientific rigor.
        </p>
        <ul>
          <li>
            <a
              href="https://linkedtarot.com/in/amyrlam"
              target="_blank"
              rel="noopener noreferrer"
              class="link-squiggle"
            >
              LinkedIn Tarot<span class="sr-only"> (opens in new tab)</span></a
            >&nbsp;— my career, read as tarot cards. Shockingly on the nose.
          </li>
          <li>
            <a
              href="https://www.eclecticenergies.com/enneagram/type4"
              target="_blank"
              rel="noopener noreferrer"
              class="link-squiggle"
            >
              My Enneagram<span class="sr-only"> (opens in new tab)</span></a
            >&nbsp;— Type 4, The Individualist. Checks out.
          </li>
        </ul>
      </div>

      <h2 class="mt-10 text-2xl font-medium tracking-tight">
        CliftonStrengths, a decade apart
      </h2>
      <p class="mt-2 text-base">
        My Gallup Top 5, taken ten years apart. Starred themes survived the decade.
      </p>

      <div class="mt-6 rounded-xl bg-white px-5 py-6 text-[#212a4a] sm:px-7 sm:py-7">
        <div class="grid gap-8 sm:grid-cols-2">
          {
            eras.map(({ year, list }) => (
              <div>
                <h3 class="text-lg font-bold tracking-wide">{year}</h3>
                <ol class="mt-3 flex flex-col gap-4">
                  {list.map((s, i) => (
                    <li class="flex gap-2.5">
                      <span class="w-4 shrink-0 text-right text-sm leading-6 tabular-nums opacity-70" aria-hidden="true">
                        {i + 1}
                      </span>
                      <span class="mt-[3px] flex h-[18px] w-[18px] shrink-0 items-center justify-center">
                        {keepers.has(s.name) && (
                          <span class="star-badge" title="In both Top 5s">
                            <span aria-hidden="true">✦</span>
                            <span class="sr-only">In both Top 5s:</span>
                          </span>
                        )}
                      </span>
                      <div>
                        <span class="flex items-center gap-2 font-bold">
                          {s.name}
                          <span
                            class={`domain-mark domain-mark--${domains[s.domain].shape} shrink-0`}
                            style={`background: ${domains[s.domain].color}`}
                            aria-hidden="true"
                          />
                          <span class="sr-only">({domains[s.domain].label})</span>
                        </span>
                        <p class="mt-1 text-sm leading-relaxed">{s.blurb}</p>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            ))
          }
        </div>

        <ul class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-xs tracking-widest" aria-label="CliftonStrengths domains">
          {
            Object.values(domains).map((d) => (
              <li class="flex items-center gap-2">
                <span
                  class={`domain-mark domain-mark--${d.shape} shrink-0`}
                  style={`background: ${d.color}`}
                  aria-hidden="true"
                />
                {d.label}
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* One mark per Gallup domain — color plus shape, so the coding survives
     colorblindness. All four sit on a 12px box; the triangle and diamond
     get a touch more width so they carry the same optical weight as the
     filled circle and square. */
  /* The "survived the decade" star, left of the theme name — a gold seal
     in a soft amber circle, so it reads as an award rather than a fifth
     entry in the domain shape system. */
  .star-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #faedd4;
    color: #b87700;
    font-size: 11px;
    line-height: 1;
  }

  .domain-mark {
    width: 12px;
    height: 12px;
  }

  .domain-mark--circle {
    border-radius: 50%;
  }

  .domain-mark--square {
    border-radius: 2px;
  }

  .domain-mark--triangle {
    width: 14px;
    clip-path: polygon(50% 0, 100% 100%, 0 100%);
  }

  .domain-mark--diamond {
    width: 13px;
    height: 13px;
    clip-path: polygon(50% 0, 100% 50%, 50% 100%, 0 50%);
  }
</style>
