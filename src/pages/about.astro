---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

/* Swap these placeholders for real photos: drop files in src/assets/about/,
   import them here, and give each an alt that says what's in the picture. */
import placeholder1 from '../assets/about/placeholder-1.svg';
import placeholder2 from '../assets/about/placeholder-2.svg';

const photos = [
  { src: placeholder1, alt: 'Placeholder — replace with a photo of Amy' },
  { src: placeholder2, alt: 'Placeholder — replace with another photo' },
];
---

<Layout title="about — Amy Lam" description="About Amy Lam.">
  <main class="relative mx-auto flex min-h-dvh max-w-2xl flex-col gap-6 px-6 pt-20 pb-32">
    <a
      href="/"
      class="relative self-start text-[19px] font-bold lowercase tracking-wide text-white transition-transform duration-300 after:absolute after:-inset-3 after:content-[''] hover:-translate-y-0.5 hover:underline hover:underline-offset-4 focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-current"
    >
      ← home
    </a>

    <h1 class="text-4xl font-medium lowercase tracking-tight sm:text-5xl">about</h1>

    <section class="sky-card rounded-2xl px-6 py-8 sm:px-10 sm:py-10">
      <div class="prose prose-lg max-w-none">
        <p>
          I'm a frontend software engineer and engineering manager with over a decade of
          experience, working at the intersection of engineering, design, and product. I'm
          especially interested in design systems, design engineering, and frontend
          platform work — anywhere the problem is really about UX and DX at the same time.
          I'm currently based in Salt Lake City, UT, and relocating to the San Francisco Bay
          Area. I'm looking for an in-office role there.
        </p>
        <p>
          I moved to Salt Lake City with my partner James during peak pandemic, drawn by
          the skiing, Alta especially. James is a tech recruiter focused on web3. Utah has
          been rough on my knees, though: I had ACL/meniscus surgery that ended up failing
          in 2026, and the silver lining is that I've become a bit of a gym rat working my
          way back. I also had a dog, Tessy, a Lakeland terrier who lived to just shy of 18
          years old.
        </p>
        <p>
          Before Salt Lake City it was Los Angeles for seven years, then San Francisco for
          eight, which is a big part of why the Bay Area is calling me back. I've missed
          being in a room with people, especially now that so much collaboration happens
          through AI tools instead.
        </p>
      </div>

      <div class="mt-8 grid grid-cols-2 gap-4">
        {photos.map((photo) => <Image src={photo.src} alt={photo.alt} class="rounded-2xl" />)}
      </div>
    </section>
  </main>
</Layout>
